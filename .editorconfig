root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true
end_of_line = crlf
indent_style = space
indent_size = 4

[*.{csproj,props,targets}]
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2

[*.cs]
# File-scoped namespaces are mandatory across the solution.
csharp_style_namespace_declarations = file_scoped:warning
dotnet_diagnostic.IDE0161.severity = warning

# Language conventions that keep the code uniform without breaking the build.
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_prefer_braces = true:suggestion
dotnet_sort_system_directives_first = true
csharp_using_directive_placement = outside_namespace:warning

# EF Core-generated migrations should not be held to code-style rules.
[**/Migrations/*.cs]
generated_code = true
dotnet_diagnostic.IDE0161.severity = none
csharp_style_namespace_declarations = file_scoped:none
